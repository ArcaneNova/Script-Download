# Environment Configuration Template
# Copy this to .env and fill in your actual values

# Telegram API Credentials (from https://my.telegram.org)
API_ID=35188145
API_HASH=3f725a3cf7a87167a58c4e098c9a1828

# Bot Token (from @BotFather on Telegram)
BOT_TOKEN=8695455961:AAFzQOswXeDgkKMbImwI8jDrTd_glAmn39k

# Destination Channel (where messages will be forwarded to)
# Format: @channelname or https://t.me/c/123456789
DESTINATION_CHANNEL=@gatearshadbackup

# Your Telegram ID (optional, for admin features)
# Get it from @userinfobot
BOT_OWNER_ID=0

# MongoDB Connection String (optional, for history tracking)
# If not set, bot uses in-memory storage
# Get free MongoDB at https://www.mongodb.com/cloud/atlas
DATABASE=

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Workers for async processing
WORKERS=4

# Rate limit delay between messages (seconds)
# Lower = faster, but risk of rate limiting
# Higher = safer, slower forwarding
RATE_LIMIT_DELAY=0.3
